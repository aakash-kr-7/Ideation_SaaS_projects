{
  "name": "shouldbuild",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "build": "next build",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run test:unit",
    "test:unit": "deno test --config supabase/functions/deno.json --allow-env --unstable-sloppy-imports lib/auth-redirect.test.ts lib/sample-reports.test.ts lib/report-mode-ui.test.ts supabase/functions/_shared/research/mode-config.test.ts supabase/functions/_shared/research/job-queue.test.ts supabase/functions/_shared/research/scoring-engine.test.ts supabase/functions/_shared/research/reasoning.test.ts supabase/functions/_shared/research/reasoning-integrity.test.ts supabase/functions/_shared/research/exports.test.ts supabase/functions/_shared/research/evidence-intelligence.test.ts supabase/functions/_shared/research/gemini.test.ts",
    "test:queue": "deno test --config supabase/functions/deno.json --allow-env supabase/functions/_shared/research/job-queue.test.ts",
    "test:gemini": "deno test --config supabase/functions/deno.json --allow-env supabase/functions/_shared/research/gemini.test.ts",
    "start": "node scripts/start-server.cjs",
    "start:3000": "node scripts/start-server.cjs --port=3000",
    "start:3001": "node scripts/start-server.cjs --port=3001",
    "lint": "eslint . --max-warnings=0",
    "check:text": "node scripts/audit-product-truth.mjs",
    "smoke:worker": "node scripts/research-worker-smoke.mjs",
    "test:pipeline": "node scripts/pipeline-integration.mjs all",
    "smoke:scheduler": "node scripts/research-scheduler-smoke.mjs",
    "test:integration": "npm run test:pipeline",
    "test:rls": "node scripts/audit-rls.mjs",
    "test:secrets": "node scripts/check-secret-leaks.mjs",
    "check:deno": "deno check --config supabase/functions/deno.json supabase/functions/research-worker/index.ts supabase/functions/research-scheduler/index.ts",
    "check": "npm run typecheck && npm run lint && npm run check:text && npm run test:secrets && npm test && npm run check:deno && npm run build"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.446.0",
    "next": "15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.4.47",
    "supabase": "^2.109.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.3"
  }
}
