{
  "name": "shouldbuild",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "build": "next build",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run test:scoring",
    "test:scoring": "deno test --unstable-sloppy-imports lib/auth-redirect.test.ts lib/sample-reports.test.ts lib/report-mode-ui.test.ts supabase/functions/_shared/research/mode-config.test.ts supabase/functions/_shared/research/job-queue.test.ts supabase/functions/_shared/research/scoring-engine.test.ts supabase/functions/_shared/research/retrieval-strategy.test.ts supabase/functions/_shared/research/reasoning.test.ts supabase/functions/_shared/research/reasoning-integrity.test.ts supabase/functions/_shared/research/exports.test.ts supabase/functions/_shared/research/providers.test.ts supabase/functions/_shared/research/discovery.test.ts supabase/functions/_shared/research/evidence-intelligence.test.ts",
    "start": "node scripts/start-server.cjs",
    "start:3000": "node scripts/start-server.cjs --port=3000",
    "start:3001": "node scripts/start-server.cjs --port=3001",
    "lint": "eslint . --max-warnings=0",
    "audit:truth": "node scripts/audit-product-truth.mjs",
    "evaluate:research": "node scripts/evaluate-research-quality.mjs",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.446.0",
    "next": "15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.3"
  }
}
